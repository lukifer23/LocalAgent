    <string name="hermes_open_termux_docs">Official Termux / Hermes docs</string>
    <string name="hermes_manual_title">Manual prerequisites (Termux)</string>
    <string name="hermes_manual_body">Enable allow-external-apps=true in ~/.termux/termux.properties so RUN_COMMAND works. Grant Termux “Draw over other apps” if Android blocks foreground sessions. Install Termux from GitHub releases (Play builds are often stale).</string>
    <string name="hermes_termux_env_title">Hermes environment in Termux</string>
    <string name="hermes_termux_env_body">Use “Push merged .env to Termux” to write ~/.hermes/.env automatically, or copy bridge variables manually. Hermes in Termux cannot read LocalAgent’s private sandbox.</string>
    <string name="hermes_push_termux_env">Push merged .env to Termux (~/.hermes/.env)</string>
    <string name="hermes_push_env_started">Started Termux .env sync — watch notifications</string>
    <string name="hermes_skills_title">Sandbox skills folder</string>
    <string name="hermes_skills_body">Files under LocalAgent synthetic ~/.hermes/skills (Hermes in Termux uses its own ~/.hermes/skills unless you mirror).</string>
